# labextend — env reference. Copy to .env and edit for local dev.
# In production, prefer docker secrets over env vars for the BPM_* keys.

# ─── role selector ──────────────────────────────────────────────────────────
# Set LEADER=true on the leader node. Otherwise set LEADER_ADDR to point an
# agent at the leader's gRPC endpoint. Exactly one of the two must be set.
LEADER=true
# LEADER_ADDR=labextend-leader:9090

# ─── network ────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
GRPC_ADDR=:9090
EXTERNAL_URL=http://localhost:8080

# ─── storage ────────────────────────────────────────────────────────────────
DATA_DIR=/data

# ─── shared secret used by both leader and agents on the gRPC channel ───────
# Generate: openssl rand -hex 32
BPM_AGENT_TOKEN=

# ─── optional mTLS — set to enable cert-based auth on top of the token ──────
# BPM_GRPC_TLS_CERT=/run/secrets/grpc.crt
# BPM_GRPC_TLS_KEY=/run/secrets/grpc.key
# BPM_GRPC_TLS_CLIENT_CA=/run/secrets/ca.crt

# ─── leader-only at-rest encryption keys ────────────────────────────────────
# Each must be 32 bytes of hex (64 chars). Generate: openssl rand -hex 32
BPM_SECRETS_KEY=
BPM_TOTP_KEY=
BPM_TOTP_ISSUER=labextend

# ─── sessions ───────────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=bpm_session
SESSION_TTL_HOURS=168
SESSION_SECURE_COOKIE=true

# ─── feature flags & limits ─────────────────────────────────────────────────
BPM_ALLOW_EXEC=false
BPM_FS_MAX_INLINE_BYTES=5242880
BPM_UPLOAD_MAX_BYTES=2147483648

# ─── agent identity (override the hostname-derived default) ─────────────────
# BPM_AGENT_HOST_ID=node-a
# BPM_AGENT_LABELS=role=worker,zone=fsn1
BPM_HEARTBEAT_INTERVAL=30s

# ─── misc ───────────────────────────────────────────────────────────────────
BPM_LOG_LEVEL=info
# CORS_ORIGINS=http://localhost:3000
# BPM_DISABLE_AUDIT=false
